# Frontend (Vite) — set these as Environment Variables in Vercel dashboard
# or in a local .env file for development

# For local dev, point to the local Express server:
#   VITE_API_BASE=http://localhost:5175/api
# For Vercel (production), use the same-domain serverless functions:
#   VITE_API_BASE=/api
VITE_API_BASE=/api

VITE_LLM_MODEL=gpt-5-nano
VITE_TERMINAL_DEBUG_LOGS=false
